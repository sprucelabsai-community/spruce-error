{
    "compilerOptions": {
        "module": "es2015",
        "target": "es6",
        "lib": [
            "es2015",
            "dom"
        ],
        "esModuleInterop": true,
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "declaration": true,
        "noImplicitAny": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitReturns": true,
        "strict": true,
        "noUnusedLocals": true,
        "resolveJsonModule": true,
        "sourceMap": false,
        "outDir": "./build",
        "rootDir": "./src",
        "baseUrl": ".",
        "types": ["node"],
        "experimentalDecorators": true,
        "paths": {
            "*": [
                "node_modules/*"
            ]
        }
    },
    "include": [
        "./*.ts",
        "./**/*.ts"
    ],
    "exclude": [
        "**/node_modules/*",
        "build/*",
        "esm/*"
    ]
}